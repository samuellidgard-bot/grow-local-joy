{
  "rewrites": [
    {
      "source": "/crm",
      "destination": "/api/crm"
    },
    {
      "source": "/crm/",
      "destination": "/api/crm"
    },
    {
      "source": "/crm/:path*",
      "destination": "/api/crm?path=:path*"
    }
  ],
  "crons": [
    {
      "path": "/crm/api/leader/cron",
      "schedule": "0 8 * * *"
    }
  ]
}
