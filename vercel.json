{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/crm",
      "destination": "/api/crm"
    },
    {
      "source": "/crm/",
      "destination": "/api/crm"
    },
    {
      "source": "/crm/:path*",
      "destination": "/api/crm?path=:path*"
    }
  ],
  "crons": [
    {
      "path": "/crm/api/leader/cron",
      "schedule": "0 8 * * *"
    }
  ]
}
